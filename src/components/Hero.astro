---
const email = 'luisalonsocelyarias@gmail.com';
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden scroll-mt-20">
  <div class="absolute inset-0 gradient-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(108,99,255,0.15),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(0,212,170,0.1),transparent_50%)]"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center lg:items-center gap-12 lg:gap-16">
      
      <div class="flex-1 text-center lg:text-left">
        <p class="text-accent2 font-semibold tracking-widest uppercase text-sm mb-4 animate-fade-in inline-flex items-center gap-2">
          <span class="w-8 h-px bg-accent2 inline-block"></span>
          Hey, bienvenido
        </p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold mb-3 leading-tight">
          <span class="text-text">Soy</span>
          <br class="sm:hidden" />
          <span class="gradient-text" id="typewriter"></span><span id="cursor" class="text-accent">|</span>
        </h1>
        <div id="underline" class="h-1 w-0 rounded-full bg-gradient-to-r from-accent to-accent2 mb-5 mx-auto lg:mx-0"></div>
        <p class="text-accent2 font-medium text-base sm:text-lg mb-4">
          Analista &amp; Desarrollador de Software
        </p>
        <p class="text-text-muted text-sm sm:text-base leading-relaxed max-w-xl mb-8 lg:mx-0">
          Especializado en el desarrollo de aplicaciones web modernas con <span class="text-text font-medium">Java &amp; Spring Boot</span>, 
          <span class="text-text font-medium">Angular</span>, <span class="text-text font-medium">Astro</span> y 
          bases de datos <span class="text-text font-medium">MySQL</span> &amp; <span class="text-text font-medium">PostgreSQL</span>. 
          Con experiencia en contenedores <span class="text-text font-medium">Docker</span> y control de versiones 
          <span class="text-text font-medium">Git</span> &amp; <span class="text-text font-medium">GitHub</span>.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-8 justify-center lg:justify-start">
          <a
            href={`mailto:${email}`}
            class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-white font-semibold px-7 py-3.5 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Contáctame
          </a>
          <a
            href="#proyectos"
            class="inline-flex items-center gap-2 border border-text-muted/30 text-text hover:border-accent hover:text-accent font-semibold px-7 py-3.5 rounded-xl transition-all duration-300"
          >
            Ver proyectos
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
        </div>
        <div class="flex items-center gap-5 justify-center lg:justify-start">
          <a href="https://github.com/louisalonzocely-cpu" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-300" aria-label="GitHub">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/luis-alonso-cely-arias-9b8816206" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="flex-shrink-0 animate-fade-in">
        <div class="relative">
          <div class="w-56 h-56 md:w-72 md:h-72 rounded-full overflow-hidden border-4 border-accent/30 shadow-2xl shadow-accent/20">
            <img src="/images/foto_perfil.jpeg" alt="Luis Alonso Cely" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -inset-4 rounded-full bg-gradient-to-br from-accent/10 to-accent2/10 blur-3xl -z-10"></div>
        </div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  #cursor {
    animation: blink 0.7s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0 }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const text = 'Luis Alonso Cely';
    const el = document.getElementById('typewriter');
    const underline = document.getElementById('underline');
    if (!el) return;
    let i = 0;
    let deleting = false;
    let paused = false;

    function step() {
      if (paused) {
        paused = false;
        setTimeout(step, deleting ? 700 : 1000);
        return;
      }

      if (!deleting) {
        i++;
        el.textContent = text.slice(0, i);
        if (i === text.length) {
          underline.style.transition = 'width 0.6s ease-out';
          underline.style.width = '100px';
          deleting = true;
          paused = true;
        }
      } else {
        i--;
        el.textContent = text.slice(0, i);
        if (i === 0) {
          underline.style.transition = 'width 0.3s ease-in';
          underline.style.width = '0';
          deleting = false;
          paused = true;
        }
      }

      if (!paused) {
        setTimeout(step, deleting ? 50 : 70);
      }
    }

    setTimeout(step, 500);
  });
</script>
