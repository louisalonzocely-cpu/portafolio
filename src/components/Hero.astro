---
const email = 'luisalonsocelyarias@gmail.com';
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden scroll-mt-20">
  <img src="/images/background-hero.png" alt="" class="absolute inset-0 w-full h-full object-cover" />
  <div class="absolute inset-0 gradient-bg opacity-60"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(108,99,255,0.15),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(0,212,170,0.1),transparent_50%)]"></div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <p class="text-accent2 font-medium tracking-widest uppercase text-sm mb-6 animate-fade-in">
      Diseñador &amp; Desarrollador Web
    </p>
    <h1 class="gradient-text text-5xl md:text-7xl lg:text-8xl font-extrabold mb-4 leading-tight min-h-[1.2em]">
      <span id="typewriter"></span><span id="cursor" class="text-accent">|</span>
    </h1>
    <div id="underline" class="h-1 w-0 mx-auto rounded-full bg-gradient-to-r from-accent to-accent2 mb-6"></div>
    <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-10">
      Creo sitios web modernos, rápidos y efectivos que ayudan a tu negocio a crecer en el mundo digital.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Contáctame
      </a>
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 border border-text-muted/30 text-text hover:border-accent hover:text-accent font-semibold px-8 py-4 rounded-xl transition-all duration-300"
      >
        Ver proyectos
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>

    <div class="flex items-center justify-center gap-5 mt-8">
      <a href="https://github.com/louisalonzocely-cpu" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-300" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a href="https://www.linkedin.com/in/luis-alonso-cely-arias-9b8816206" target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors duration-300" aria-label="LinkedIn">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  #cursor {
    animation: blink 0.7s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0 }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const text = 'Luis Alonso Cely';
    const el = document.getElementById('typewriter');
    const underline = document.getElementById('underline');
    if (!el) return;
    let i = 0;
    let deleting = false;
    let paused = false;

    function step() {
      if (paused) {
        paused = false;
        setTimeout(step, deleting ? 700 : 1000);
        return;
      }

      if (!deleting) {
        i++;
        el.textContent = text.slice(0, i);
        if (i === text.length) {
          underline.style.transition = 'width 0.6s ease-out';
          underline.style.width = '120px';
          deleting = true;
          paused = true;
        }
      } else {
        i--;
        el.textContent = text.slice(0, i);
        if (i === 0) {
          underline.style.transition = 'width 0.3s ease-in';
          underline.style.width = '0';
          deleting = false;
          paused = true;
        }
      }

      if (!paused) {
        setTimeout(step, deleting ? 50 : 70);
      }
    }

    setTimeout(step, 500);
  });
</script>
