---
const email = 'luisalonsocelyarias@gmail.com';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 gradient-bg"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_rgba(108,99,255,0.15),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_rgba(0,212,170,0.1),transparent_50%)]"></div>

  <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
    <p class="text-accent2 font-medium tracking-widest uppercase text-sm mb-6 animate-fade-in">
      Diseñador &amp; Desarrollador Web
    </p>
    <h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold mb-6 leading-tight">
      Luis Alonso <span class="gradient-text">Cely</span>
    </h1>
    <p class="text-lg md:text-xl text-text-muted max-w-2xl mx-auto mb-10">
      Creo sitios web modernos, rápidos y efectivos que ayudan a tu negocio a crecer en el mundo digital.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={`mailto:${email}`}
        class="inline-flex items-center gap-2 bg-accent hover:bg-accent-light text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:shadow-lg hover:shadow-accent/25"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        Contáctame
      </a>
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 border border-text-muted/30 text-text hover:border-accent hover:text-accent font-semibold px-8 py-4 rounded-xl transition-all duration-300"
      >
        Ver proyectos
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
