---
const project = {
  title: 'Restaurante Don Juan',
  subtitle: 'Sitio web completo para restaurante',
  description: 'Sitio web profesional para el Restaurante Don Juan en Cartagena de Indias, Colombia. Incluye menú digital interactivo, galería de imágenes, ubicación con Google Maps integrado, horarios, contacto directo por WhatsApp y reservas.',
  tech: ['Astro', 'JavaScript', 'CSS', 'Google Maps API', 'EmailJS'],
  url: 'https://restaurante-donjuan-web.pages.dev',
  github: 'https://github.com/louisalonzocely-cpu/restaurante_donjuan_web',
  image: '/images/donjuan-preview.png',
};
---

<section id="proyectos" class="py-16 px-4 bg-surface/20 scroll-mt-20">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-10">
      <p class="text-accent font-medium tracking-widest uppercase text-xs mb-2">Proyectos</p>
      <h2 class="text-2xl md:text-3xl font-bold">Trabajos recientes</h2>
    </div>

    <div class="project-card bg-surface/50 backdrop-blur-sm border border-white/5 rounded-xl overflow-hidden max-w-sm mx-auto">
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="block">
        <div class="h-40 sm:h-48 bg-surface overflow-hidden">
          {project.image ? (
            <img src={project.image} alt={project.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-text-muted">
              <span class="text-4xl">🍽️</span>
            </div>
          )}
        </div>
      </a>
      <div class="p-5">
        <p class="text-accent2 font-medium text-xs mb-1">{project.subtitle}</p>
        <h3 class="text-lg font-bold mb-2">{project.title}</h3>
        <p class="text-text-muted text-xs leading-relaxed mb-4">{project.description}</p>
        <div class="flex flex-wrap gap-1.5 mb-4">
          {project.tech.map((tech) => (
            <span class="px-2 py-0.5 bg-accent/10 text-accent text-xs rounded-md font-medium">{tech}</span>
          ))}
        </div>
        <div class="flex flex-wrap gap-2">
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 bg-accent hover:bg-accent-light text-white font-semibold text-xs px-4 py-2 rounded-lg transition-all duration-300"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Visitar sitio
          </a>
          <a
            href={project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 border border-text-muted/30 text-text hover:border-accent hover:text-accent font-semibold text-xs px-4 py-2 rounded-lg transition-all duration-300"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Código fuente
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
