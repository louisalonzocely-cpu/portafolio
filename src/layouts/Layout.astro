---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Luis Alonso Cely | Diseñador & Desarrollador Web', description = 'Diseñador y desarrollador web de Colombia. Creo sitios web modernos, rápidos y efectivos para impulsar tu negocio.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="description" content={description} />
    <meta name="author" content="Luis Alonso Cely" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-dark text-text">
    <slot />
  </body>
</html>
